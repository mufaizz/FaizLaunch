{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist/main",
    "rootDir": "./",
    "noImplicitAny": false,
    "noEmitOnError": false,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["main/**/*", "shared/**/*"]
}
